# Step 1:
# Copy this file and rename the copy to ".env".
#
# Windows:
# copy backend\.env.example backend\.env
#
# Step 2:
# Paste your real API key in LLM_API_KEYS inside backend/.env.
#
# Do not put real keys in this .env.example file.

# auto detects Gemini (AIza...), Anthropic (sk-ant-...), OpenRouter (sk-or-...), or OpenAI (sk-...).
LLM_PROVIDER=auto
LLM_API_KEYS=paste_your_real_api_key_here
# OpenRouter default used by this POC.
LLM_MODEL=deepseek/deepseek-v4-pro
# Used only by Gemini; other providers ignore it.
LLM_FALLBACK_MODELS=gemini-2.5-flash-lite,gemini-2.0-flash
LLM_BASE_URL=
LLM_TIMEOUT_SECONDS=30
QUERY_ROW_LIMIT=100
# 5 GB default. Increase only if your machine has enough disk space.
MAX_UPLOAD_BYTES=5368709120

# MCP: paste the full path of the SQLite database MCP should access.
# Example: C:\data\sales.sqlite
MCP_DATABASE_PATH=

# Optional response cache. Example: redis://localhost:6379/0
REDIS_URL=
CACHE_TTL_SECONDS=3600

# SQL Server live .sql import. Set SQLSERVER_IMPORT_SQL=1 only when SQL Server is running.
SQLSERVER_IMPORT_SQL=0
MSSQL_SA_PASSWORD=ChangeThisStrongPassword123!
MSSQL_DATABASE=SqlAssistant
SQLSERVER_HOST=127.0.0.1
SQLSERVER_PORT=1433
SQLSERVER_DATABASE=SqlAssistant
SQLSERVER_USERNAME=sa
SQLSERVER_PASSWORD=ChangeThisStrongPassword123!
SQLSERVER_ENCRYPT=yes
SQLSERVER_TRUST_CERT=yes
SQLSERVER_QUERY_TIMEOUT_SECONDS=30
LIVE_DATABASE_CACHE_TTL_SECONDS=300
